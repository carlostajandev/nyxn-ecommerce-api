# ─────────────────────────────────────────────────────────────────────────────
# .env.example — NYXN E-Commerce Monorepo
#
# Copy this file to .env and fill in the values before running docker-compose.
#   cp .env.example .env
#
# .env is in .gitignore — never commit real credentials to version control.
# In production, use GCP Secret Manager (or equivalent) to inject secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=nyxn_ecommerce
POSTGRES_USER=nyxn
POSTGRES_PASSWORD=nyxn_local_dev

# ── Spring Boot backend ───────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://postgres:5432/nyxn_ecommerce
DB_USERNAME=nyxn
DB_PASSWORD=nyxn_local_dev
REDIS_HOST=redis
REDIS_PORT=6379
SPRING_PROFILES_ACTIVE=docker

# ── GCP Pub/Sub (emulator for local dev, leave blank for real GCP) ────────────
GCP_PROJECT_ID=local-project
# PUBSUB_EMULATOR_HOST is set automatically by docker-compose for the emulator.
# For production, remove this variable so Spring Cloud GCP uses real credentials.
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
SPRING_CLOUD_GCP_PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
SPRING_CLOUD_GCP_PROJECT_ID=local-project

# ── NestJS notification service ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000
PUBSUB_SUBSCRIPTION_PRODUCT_EVENTS=product-events-subscription

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Required for POST /agent/smart-notification.
# Get your key at: https://console.anthropic.com/settings/keys
# Leave blank to run without AI (the endpoint returns 500 when not set).
ANTHROPIC_API_KEY=
