# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit secrets.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── GCP Pub/Sub ──────────────────────────────────────────────────────────────
# For local development with docker-compose, set this to point at the emulator.
# For GCP production, leave unset — the client library uses Application Default Credentials.
PUBSUB_EMULATOR_HOST=localhost:8085
GCP_PROJECT_ID=local-project
PUBSUB_SUBSCRIPTION_PRODUCT_EVENTS=product-events-subscription

# ─── Claude AI (Section 6B) ───────────────────────────────────────────────────
# Required for the /agent/smart-notification endpoint.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
